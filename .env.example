SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"your_project_id",...}

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI API Key (for AI-powered conversation)
OPENAI_API_KEY=your_openai_api_key_here

# CORS Settings (comma-separated list of allowed origins)
# For development: CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# For production: CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=*
